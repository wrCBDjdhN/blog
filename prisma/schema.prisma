generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String
  name       String?
  role       String    @default("user")
  avatar     String?
  bio        String?
  github     String?
  twitter    String?
  bilibili   String?
  isVerified Boolean   @default(false)
  createdAt  DateTime  @default(now())
  posts      Post[]
  comments   Comment[]
  likes      Like[]

  @@index([email])
}

model Post {
  id          String    @id @default(cuid())
  title       String
  content     String
  summary    String?
  coverImage String?
  published  Boolean   @default(true)
  viewCount  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  authorId   String
  author     User      @relation(fields: [authorId], references: [id])
  comments   Comment[]
  likes     Like[]

  @@index([authorId])
  @@index([published])
}

model Product {
  id           String   @id @default(cuid())
  name         String
  description  String
  price        Float
  coverImage   String?
  images       String   @default("[]")
  published   Boolean  @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  comments     Comment[]
  likes       Like[]

  @@index([published])
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  nickname  String?
  createdAt DateTime  @default(now())
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  productId String?
  product   Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([postId])
  @@index([productId])
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@unique([productId, userId])

  @@index([postId])
  @@index([productId])
  @@index([userId])
}

model Order {
  id          String    @id @default(cuid())
  orderNumber String   @unique
  productId   String
  productName String
  price       Float
  buyerName  String
  buyerEmail String
  status     String
  createdAt  DateTime  @default(now())
  paidAt     DateTime?

  @@index([orderNumber])
  @@index([buyerEmail])
}

model RateLimit {
  id        String   @id @default(cuid())
  identifier String  @unique
  count     Int      @default(1)
  firstAttempt BigInt
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Payment {
  id           String   @id @default(cuid())
  outTradeNo   String   @unique  // 商户订单号
  productId   String?          // 如果是购买商品
  productName String?          // 商品名称
  amount      Int              // 支付金额(分, 固定金额如 1元=100)
  description String?          // 支付描述
  status      String   @default("pending") // pending/success/expired/closed
  openid      String?          // 用户openid
  transactionId String?      // 微信交易号
  paidAt      DateTime?       // 支付时间
  expiresAt   DateTime       // 过期时间
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([outTradeNo])
  @@index([status])
  @@index([expiresAt])
}

model FriendLink {
  id          String   @id @default(cuid())
  name        String   // 网站名称
  url         String   // 网站URL
  description String?  // 描述
  avatar      String?  // 头像URL
  order       Int      @default(0) // 排序
  status      String   @default("pending") // pending/approved/rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([order])
}